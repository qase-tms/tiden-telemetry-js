{
  "name": "@tiden/telemetry-sourcemaps",
  "version": "0.1.6",
  "description": "Tiden source-map bundler plugin (unplugin). Injects debug-ids and uploads source maps to a Tiden product at build time. No third-party error-SDK dependency.",
  "keywords": [
    "tiden",
    "source-maps",
    "debug-id",
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "esbuild"
  ],
  "homepage": "https://github.com/qase-tms/tiden-telemetry-js/tree/main/sourcemaps",
  "bugs": "https://github.com/qase-tms/tiden-telemetry-js/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qase-tms/tiden-telemetry-js.git",
    "directory": "sourcemaps"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:publish": "publint --strict && attw --pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "tinyglobby": "^0.2.17",
    "unplugin": "^2.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.1",
    "globals": "^16.4.0",
    "publint": "^0.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}

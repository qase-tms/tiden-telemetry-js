{
  "name": "@tiden/telemetry-browser",
  "version": "0.1.5",
  "description": "Tiden error-tracking browser SDK. Emits the envelope wire format to a Tiden ingest endpoint, with no third-party error-SDK dependency.",
  "keywords": [
    "tiden",
    "error-tracking",
    "browser",
    "sdk"
  ],
  "homepage": "https://github.com/qase-tms/tiden-telemetry-js/tree/main/browser",
  "bugs": "https://github.com/qase-tms/tiden-telemetry-js/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qase-tms/tiden-telemetry-js.git",
    "directory": "browser"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:publish": "publint --strict && attw --pack",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "stacktrace-parser": "^0.1.11"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^10.4.1",
    "globals": "^16.4.0",
    "publint": "^0.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
